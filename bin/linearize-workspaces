#!/usr/bin/env bash
# linearize-workspaces — stack all mutable jj heads onto trunk as a single
# linear chain, then drop empty & undescribed commits.
#
# Scope is deliberately narrow: it only stacks branches and cleans up empties.
# It does NOT resolve conflicts (jj records them in the rebased commits — run
# `pi-resolve-conflicts`, or resolve by hand, afterwards), does NOT run tests,
# and does NOT auto `update-stale` workspaces (it only reports stale ones).
set -euo pipefail

########################################################################
# Arg parsing
########################################################################
REPO_ROOT=""
BASE_REV="trunk()"
TARGET_WS=""
DRY_RUN=false
KEEP_EMPTY=false

usage() {
  cat <<'EOF'
Usage: linearize-workspaces [OPTIONS]

Stack all mutable jj heads onto trunk as a single linear chain. Finds all
heads of mutable commits off trunk(), sorts them by author timestamp (oldest
first), then chain-rebases each onto the growing tip. Afterwards, drops
commits that are both empty AND undescribed (never a workspace working copy).

Conflicts are NOT resolved — jj records them in the rebased commits. Resolve
them yourself afterwards, e.g.:  jj edit <id> && pi-resolve-conflicts

Options:
  -R, --repo PATH       Repo root (default: auto-detect via jj root)
  -b, --base REV        Base revision to stack onto (default: trunk())
  -w, --workspace NAME  Only rebase the branch containing this workspace
  --keep-empty          Don't drop empty & undescribed commits
  --dry-run             Show what would be done, don't do it
  -h, --help            Show this help
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -R|--repo)       REPO_ROOT="$2"; shift 2 ;;
    -b|--base)       BASE_REV="$2"; shift 2 ;;
    -w|--workspace)  TARGET_WS="$2"; shift 2 ;;
    --keep-empty)    KEEP_EMPTY=true; shift ;;
    --dry-run)       DRY_RUN=true; shift ;;
    -h|--help)       usage ;;
    *)               echo "Unknown flag: $1"; usage ;;
  esac
done

########################################################################
# Resolve repo root
########################################################################
if [[ -z "$REPO_ROOT" ]]; then
  REPO_ROOT="$(jj root 2>/dev/null || echo "")"
  if [[ -z "$REPO_ROOT" ]]; then
    echo "error: not in a jj repo and no --repo given" >&2
    exit 1
  fi
fi
REPO_ROOT="$(cd "$REPO_ROOT" && pwd)"

########################################################################
# Resolve base display name
########################################################################
BASE_DISPLAY="$BASE_REV"
if [[ "$BASE_REV" == "trunk()" ]]; then
  resolved=$(jj -R "$REPO_ROOT" log -r 'trunk()' --no-graph \
    -T 'bookmarks ++ " (" ++ commit_id.short() ++ ")"' 2>/dev/null || echo "trunk")
  BASE_DISPLAY="$resolved"
fi

echo "→ repo:  $REPO_ROOT"
echo "→ base:  $BASE_DISPLAY"
echo ""

########################################################################
# Discover mutable heads off trunk, sorted oldest-first by timestamp
########################################################################
discover_heads() {
  # Output: timestamp|change_id|description  (pipe-delimited, sorted oldest-first)
  jj -R "$REPO_ROOT" log -r 'heads(trunk():: & ~trunk())' --no-graph \
    -T 'author.timestamp() ++ "|" ++ change_id.short() ++ "|" ++ description.first_line() ++ "\n"' 2>/dev/null \
    | sort
}

########################################################################
# Main logic
########################################################################
FAILURES=()

if [[ -n "$TARGET_WS" ]]; then
  # ── Single-workspace mode: rebase only this workspace's branch onto base ──
  ws_dir=$(jj -R "$REPO_ROOT" workspace root --name "$TARGET_WS" 2>/dev/null || echo "")
  if [[ -z "$ws_dir" ]]; then
    echo "✗ workspace '$TARGET_WS' not found"
    exit 1
  fi
  echo "── workspace: $TARGET_WS ($ws_dir) ──"

  if ! jj -R "$ws_dir" st &>/dev/null; then
    echo "  ✗ workspace is stale. Run this first:"
    echo "      jj -R $ws_dir workspace update-stale"
    echo "    (update-stale can discard uncommitted changes — see the jj"
    echo "     skill's Stale Workspaces section.)"
    exit 1
  fi

  branch_revs=$(jj -R "$ws_dir" log -r "$BASE_REV..@" --no-graph \
    -T 'commit_id.short() ++ " " ++ description.first_line() ++ "\n"' 2>/dev/null || echo "")
  branch_revs_trimmed=$(echo "$branch_revs" | tr -d '[:space:]')

  if [[ -z "$branch_revs_trimmed" ]]; then
    echo "  ✓ already on $BASE_DISPLAY, nothing to rebase"
  else
    echo "  commits to rebase:"
    echo "$branch_revs" | while read -r line; do
      [[ -n "$line" ]] && printf "    %s\n" "$line"
    done

    if [[ "$DRY_RUN" == true ]]; then
      echo "  [dry-run] would: jj rebase -b @ -d $BASE_REV"
    else
      echo "  rebasing..."
      if jj -R "$ws_dir" rebase -b @ -d "$BASE_REV" 2>&1; then
        echo "  ✓ rebase ok"
      else
        echo "  ✗ rebase failed"
        FAILURES+=("$TARGET_WS: rebase command failed")
      fi
    fi
  fi

else
  # ── Full mode: chain-rebase all mutable heads onto trunk ──
  HEADS=$(discover_heads)

  if [[ -z "$HEADS" ]]; then
    echo "✓ no mutable branches off $BASE_DISPLAY — nothing to do"
  else
    head_count=$(echo "$HEADS" | wc -l | tr -d ' ')
    echo "→ mutable heads off $BASE_DISPLAY: $head_count"
    echo ""

    CURRENT="$BASE_REV"

    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      ts="${line%%|*}"
      rest="${line#*|}"
      head_id="${rest%%|*}"
      desc="${rest#*|}"
      [[ -z "$desc" || "$desc" == "$head_id" ]] && desc="(no description)"

      echo "── head $head_id ($ts) $desc ──"

      # Show commits in this branch (ancestors of head not in current base)
      branch_revs=$(jj -R "$REPO_ROOT" log -r "$CURRENT..$head_id" --no-graph \
        -T 'commit_id.short() ++ " " ++ description.first_line() ++ "\n"' 2>/dev/null || echo "")
      branch_trimmed=$(echo "$branch_revs" | tr -d '[:space:]')

      if [[ -z "$branch_trimmed" ]]; then
        echo "  ✓ already reachable from current tip, skipping"
        CURRENT="$head_id"
        continue
      fi

      echo "  commits to rebase:"
      echo "$branch_revs" | while read -r bl; do
        [[ -n "$bl" ]] && printf "    %s\n" "$bl"
      done

      if [[ "$DRY_RUN" == true ]]; then
        echo "  [dry-run] would: jj rebase -b $head_id -d $CURRENT"
        CURRENT="$head_id"
        continue
      fi

      # ── Rebase this head's branch onto the growing tip ──
      # jj records conflicts in the rebased commits rather than failing, so a
      # zero exit here does not imply a clean rebase — conflicts are reported
      # together at the end.
      echo "  rebasing..."
      if ! jj -R "$REPO_ROOT" rebase -b "$head_id" -d "$CURRENT" 2>&1; then
        echo "  ✗ rebase command failed"
        FAILURES+=("head $head_id: rebase command failed")
        continue
      fi
      echo "  ✓ rebase ok"

      # Advance the tip for the next head
      CURRENT="$head_id"
    done <<< "$HEADS"
  fi
fi

########################################################################
# Drop empty & undescribed commits
########################################################################
# Intersection on purpose: an empty-but-described commit is an intentional
# marker, and a described-but-nonempty commit is real work — only commits that
# are both empty and undescribed are pure noise. working_copies() is excluded
# so we never abandon a workspace's working-copy commit.
DROP_REVSET='mutable() & empty() & description(exact:"") & ~working_copies()'
if [[ "$KEEP_EMPTY" != true ]]; then
  echo ""
  echo "── dropping empty & undescribed commits ──"
  drop_list=$(jj -R "$REPO_ROOT" log -r "$DROP_REVSET" --no-graph \
    -T 'change_id.shortest(8) ++ " " ++ commit_id.short() ++ "\n"' 2>/dev/null || echo "")
  drop_trimmed=$(echo "$drop_list" | tr -d '[:space:]')
  if [[ -z "$drop_trimmed" ]]; then
    echo "  ✓ none to drop"
  else
    echo "$drop_list" | while read -r c; do [[ -n "$c" ]] && echo "    $c"; done
    if [[ "$DRY_RUN" == true ]]; then
      echo "  [dry-run] would: jj abandon -r '$DROP_REVSET'"
    elif jj -R "$REPO_ROOT" abandon -r "$DROP_REVSET" 2>&1; then
      echo "  ✓ dropped"
    else
      echo "  ✗ abandon failed"
      FAILURES+=("drop empties: jj abandon failed")
    fi
  fi
fi

########################################################################
# Report conflicts (left for pi-resolve-conflicts / manual fix)
########################################################################
echo ""
echo "── conflicts ──"
conflicted=$(jj -R "$REPO_ROOT" log -r 'mutable() & conflicts()' --no-graph \
  -T 'change_id.shortest(8) ++ " " ++ description.first_line() ++ "\n"' 2>/dev/null || echo "")
conflicted_trimmed=$(echo "$conflicted" | tr -d '[:space:]')
if [[ -z "$conflicted_trimmed" ]]; then
  echo "  ✓ no conflicts"
else
  echo "  ⚠ conflicted commits — resolve each with:"
  echo "      jj edit <id> && pi-resolve-conflicts"
  echo "$conflicted" | while read -r c; do [[ -n "$c" ]] && echo "    $c"; done
fi

########################################################################
# Report stale workspaces (read-only — does NOT auto update-stale)
########################################################################
echo ""
echo "── workspace staleness ──"
STALE_ANY=false
workspaces=$(jj -R "$REPO_ROOT" workspace list --no-pager 2>/dev/null | awk -F': ' '{print $1}')
for ws_name in $workspaces; do
  ws_dir=$(jj -R "$REPO_ROOT" workspace root --name "$ws_name" 2>/dev/null || echo "")
  [[ -z "$ws_dir" ]] && continue
  if ! jj -R "$ws_dir" st &>/dev/null; then
    echo "  ⚠ $ws_name is stale — run: jj -R $ws_dir workspace update-stale"
    STALE_ANY=true
  fi
done
if [[ "$STALE_ANY" != true ]]; then
  echo "  ✓ all workspaces fresh"
else
  echo "  (update-stale can discard uncommitted changes — see the jj skill.)"
fi

########################################################################
# Summary
########################################################################
echo ""
echo "═══════════════════════════════════════"
if [[ ${#FAILURES[@]} -eq 0 ]]; then
  echo "✓ done — heads linearized onto $BASE_DISPLAY"
  exit 0
else
  echo "✗ problems encountered:"
  for f in "${FAILURES[@]}"; do
    echo "  - $f"
  done
  exit 1
fi
