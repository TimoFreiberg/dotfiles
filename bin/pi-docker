#!/usr/bin/env bash
# pi-docker — run pi (coding agent) interactively inside a Docker container
#
# Usage:
#   pi-docker [options] [--] <command...>
#   pi-docker                        # runs `pi` with configured defaults
#   pi-docker bash                   # interactive shell in the container
#   pi-docker pi --provider deepseek --model deepseek-v4-flash
#   pi-docker -- --provider deepseek "Refactor the error handling"
#
# Options:
#   --workspace DIR       Project directory to mount (default: current directory)
#   --image NAME          Container image (default: pi-container)
#   --name NAME           Container name (default: pi-<random>)
#   --no-build            Don't try to build the image, fail if absent
#   --provider NAME       LLM provider (overrides settings.json)
#   --model NAME          Model name (overrides settings.json)
#   --host-network         Use host network stack (default: isolated bridge, API only)
#   --help                Show this message
#
# Environment:
#   CONTAINER_CMD         Container runtime (default: docker)
#   PI_DOCKER_IMAGE       Image name override
#   PI_OFFLINE            Disable pi online features (default: 1 in container)

set -euo pipefail

# ---------------------------------------------------------------------------
# Config
# ---------------------------------------------------------------------------

IMAGE="${PI_DOCKER_IMAGE:-pi-container}"
WORKSPACE=""
CONTAINER_NAME=""
NO_BUILD=""
PROVIDER=""
MODEL=""
NETWORK=""
RUNTIME="${CONTAINER_CMD:-docker}"
DOTFILES_DIR="$HOME/dotfiles"
EXTENSION_DIR="$DOTFILES_DIR/agents/extensions/container"
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

POSITIONAL=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --workspace) WORKSPACE="$2"; shift 2 ;;
        --image) IMAGE="$2"; shift 2 ;;
        --name) CONTAINER_NAME="$2"; shift 2 ;;
        --no-build) NO_BUILD=1; shift ;;
        --provider) PROVIDER="$2"; shift 2 ;;
        --model) MODEL="$2"; shift 2 ;;
        --host-network) NETWORK=1; shift ;;
        --help)
            sed -n '2,/^$/{ /^$/d; p; }' "$0"
            exit 0
            ;;
        --) shift; POSITIONAL+=("$@"); break ;;
        -*) echo "error: unknown option: $1" >&2; exit 1 ;;
        *) POSITIONAL+=("$1"); shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

: "${WORKSPACE:=$(pwd)}"
: "${CONTAINER_NAME:=pi-$(openssl rand -hex 4)}"

# Resolve to absolute paths
CALLER_PWD="$(pwd)"
WORKSPACE="$(cd "$WORKSPACE" 2>/dev/null && pwd)" || {
    echo "error: workspace not found: $WORKSPACE" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Runtime check
# ---------------------------------------------------------------------------

if ! command -v "$RUNTIME" &>/dev/null; then
    echo "error: container runtime '$RUNTIME' not found" >&2
    echo "Install Docker (orbstack, docker desktop) or set CONTAINER_CMD" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Build image if needed
# ---------------------------------------------------------------------------

if [ "$NO_BUILD" != "1" ]; then
    if ! "$RUNTIME" image inspect "$IMAGE" &>/dev/null; then
        echo "Building image '$IMAGE' from $EXTENSION_DIR..."
        "$RUNTIME" build -t "$IMAGE" -f "$EXTENSION_DIR/Dockerfile" "$EXTENSION_DIR"
        echo "done."
    fi
fi

# ---------------------------------------------------------------------------
# Config dir
# ---------------------------------------------------------------------------

# Mount the host's pi config directory directly so sessions, history,
# auth, and todos persist seamlessly across container runs.
#
# Resolve symlinks to get the real path: ~/.pi/agent is usually a symlink
# to ~/dotfiles/config/pi/agent/, and the AGENTS.md/skills symlinks inside
# it are relative to that real location. Mounting at the real path keeps
# those relative symlinks resolving correctly.
PI_CONFIG_REAL="$(cd "$HOME/.pi/agent" && pwd -P 2>/dev/null)" || {
    echo "error: pi config dir not found at $HOME/.pi/agent" >&2
    exit 1
}

# ---------------------------------------------------------------------------
# Build docker run command
# ---------------------------------------------------------------------------

DOCKER_ARGS=(
    run
    -it --rm
    --name "$CONTAINER_NAME"
    --hostname pi-container
    -u "$HOST_UID:$HOST_GID"
)

# --- Network ---
# Default bridge: containers can reach the internet (API access works).
# --host-network: share host network stack (for git remotes on localhost, etc.)
if [ "$NETWORK" = "1" ]; then
    DOCKER_ARGS+=(--network host)
fi

# --- Mounts ---
DOCKER_ARGS+=(-v "$WORKSPACE:$WORKSPACE:rw")

# Mount dotfiles at its real host path so existing symlinks inside the
# pi config dir (which point to ~/dotfiles/agents/*) resolve correctly.
# Skip if workspace is already the dotfiles dir (would be a duplicate mount).
if [ "$WORKSPACE" != "$DOTFILES_DIR" ]; then
    DOCKER_ARGS+=(-v "$DOTFILES_DIR:$DOTFILES_DIR:ro")
fi
# Mount pi config directly from the host — sessions, auth, history persist.
DOCKER_ARGS+=(-v "$PI_CONFIG_REAL:$PI_CONFIG_REAL:rw")

# Optional: mount .gitconfig for sensible git commits inside the container.
if [ -f "$HOME/.gitconfig" ]; then
    DOCKER_ARGS+=(-v "$HOME/.gitconfig:/home/pi/.gitconfig:ro")
fi

# Optional: mount jj config for correct commit authorship inside the container.
# jj reads config from $HOME/.config/jj/ (including conf.d/*.toml for
# user.name/user.email and SSH signing settings).
if [ -d "$HOME/.config/jj" ]; then
    DOCKER_ARGS+=(-v "$HOME/.config/jj:/home/pi/.config/jj:ro")
fi

# --- Environment ---
DOCKER_ARGS+=(
    -e PI_CODING_AGENT_DIR="$PI_CONFIG_REAL"
    -e "PI_OFFLINE=${PI_OFFLINE:-1}"
    -e HOME=/home/pi
)

# --- Working directory ---
DOCKER_ARGS+=(-w "$CALLER_PWD")

# --- Image ---
DOCKER_ARGS+=("$IMAGE")

# --- Command ---
PI_ARGS=()
[ -n "$PROVIDER" ] && PI_ARGS+=(--provider "$PROVIDER")
[ -n "$MODEL" ] && PI_ARGS+=(--model "$MODEL")

if [ ${#POSITIONAL[@]} -eq 0 ]; then
    # Default: run pi interactively
    DOCKER_ARGS+=(pi "${PI_ARGS[@]}")
else
    DOCKER_ARGS+=("${POSITIONAL[@]}")
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------

echo "pi-container: $CONTAINER_NAME"
echo "  workspace: $WORKSPACE"
echo "  workdir:   $CALLER_PWD"
echo "  dotfiles:  $DOTFILES_DIR"
echo "  user:      $HOST_UID:$HOST_GID"
[ -n "$PROVIDER" ] && echo "  provider:  $PROVIDER"
[ -n "$MODEL" ] && echo "  model:     $MODEL"
echo ""

# ---------------------------------------------------------------------------
# Run
# ---------------------------------------------------------------------------

"$RUNTIME" "${DOCKER_ARGS[@]}"
