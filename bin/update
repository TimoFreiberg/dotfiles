#!/usr/bin/env fish

# Daily system updater
# Runs all update commands sequentially, printing normal output.

set -l had_errors 0

# Fetch + fast-forward a jj-backed repo's bookmark to its origin counterpart.
# Returns nonzero if a step failed; a missing dir is a soft skip (return 0),
# since some repos (e.g. work checkouts) only exist on certain machines.
function update_jj_repo --argument-names name dir bookmark
    if not test -d "$dir"
        echo "  ℹ  $dir not found — skipping $name"
        return 0
    end

    cd "$dir"
    set -l had_err 0

    echo "  $name: fetching from origin..."
    jj git fetch; or begin
        echo "  ⚠ $name: jj git fetch failed (exit $status)"; set had_err 1
    end

    # Check if $bookmark@origin exists after fetch
    if jj log -r "$bookmark@origin" --no-graph 2>/dev/null | head -1 | string match -q '*'
        set -l local_id (jj log -r "$bookmark" --no-graph -T 'commit_id' 2>/dev/null)
        set -l origin_id (jj log -r "$bookmark@origin" --no-graph -T 'commit_id' 2>/dev/null)

        if test "$local_id" = "$origin_id"
            echo "  ✓ $name: $bookmark is already up to date with origin"
        else if jj log -r "$bookmark::$bookmark@origin" --no-graph 2>/dev/null | grep -q .
            echo "  $name: fast-forwarding $bookmark to $bookmark@origin..."
            jj bookmark set $bookmark -r $bookmark@origin; and echo "  ✓ $name: $bookmark fast-forwarded"; or begin
                echo "  ⚠ $name: fast-forward failed (exit $status)"; set had_err 1
            end
        else
            echo "  ⚠ $name: $bookmark has diverged from origin — cannot fast-forward"
            echo "     (local $bookmark is not an ancestor of origin's $bookmark)"
        end
    else
        echo "  ℹ  $name: $bookmark@origin not found after fetch — skipping fast-forward"
    end

    cd -
    return $had_err
end

echo "========================================"
echo "           Daily System Update"
echo "========================================"
echo ""

# ──────────────────────────────────────────────
# 1. Homebrew
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo " 1/6  brew upgrade"
echo "──────────────────────────────────────────"
brew upgrade; or begin
    echo "  ⚠ brew upgrade failed (exit $status)"; set had_errors 1
end

echo "  Cleaning up old versions..."
brew cleanup; or begin
    echo "  ⚠ brew cleanup failed (exit $status)"; set had_errors 1
end

echo "  Removing unused dependencies..."
brew autoremove; or begin
    echo "  ⚠ brew autoremove failed (exit $status)"; set had_errors 1
end
echo ""

# ──────────────────────────────────────────────
# macOS system updates
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo "      softwareupdate (list only)"
echo "──────────────────────────────────────────"

set -l swupd_tmp (mktemp)
softwareupdate --list > $swupd_tmp 2>&1
set -l swupd_exit $status

cat $swupd_tmp

if test $swupd_exit -ne 0
    echo "  ⚠ softwareupdate --list failed"
    set had_errors 1
    set -g swupd_pending 0
else if grep -q "No new software available" $swupd_tmp
    set -g swupd_pending 0
else
    set -g swupd_pending (grep -c "^* Label:" $swupd_tmp)
    set -g swupd_labels (grep "^* Label:" $swupd_tmp | sed 's/^* Label: //')
    echo ""
    echo "  → $swupd_pending update(s) available (install manually: softwareupdate --install --all)"
end

rm -f $swupd_tmp
echo ""

# ──────────────────────────────────────────────
# 2. Rust toolchain
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo " 2/6  rustup update"
echo "──────────────────────────────────────────"
rustup update; or begin
    echo "  ⚠ rustup update failed (exit $status)"; set had_errors 1
end
echo ""

echo "──────────────────────────────────────────"
echo "      cargo tool updates"
echo "──────────────────────────────────────────"

# Install cargo-binstall if missing, otherwise update it.
if command -v cargo-binstall > /dev/null 2>&1
    echo "  Updating cargo-binstall..."
    cargo binstall cargo-binstall -y; or begin
        echo "  ⚠ cargo-binstall update failed (exit $status)"; set had_errors 1
    end
else
    echo "  Installing cargo-binstall..."
    curl -L --proto '=https' --tlsv1.2 -sSf \
        https://raw.githubusercontent.com/cargo-bins/cargo-binstall/main/install-from-binstall-release.sh \
        | bash; or begin
        echo "  ⚠ cargo-binstall installation failed (exit $status)"; set had_errors 1
    end
end

# Update cargo-installed tools via binstall (pre-built binaries)
echo "  Updating cargo-nextest..."
cargo nextest self update -y; or begin
    echo "  ⚠ cargo-nextest update failed (exit $status)"; set had_errors 1
end
echo "  Updating cargo-sweep..."
cargo binstall cargo-sweep -y; or begin
    echo "  ⚠ cargo binstall failed (exit $status)"; set had_errors 1
end
echo ""

echo "──────────────────────────────────────────"
echo "      cargo sweep (clean old builds)"
echo "──────────────────────────────────────────"
# --time 3 = remove artifacts older than 3 days.
# -r = recursive scan for Cargo workspaces.
cargo sweep --time 3 -r ~/src; or begin
    echo "  ⚠ cargo sweep failed (exit $status)"; set had_errors 1
end
echo ""

# ──────────────────────────────────────────────
# 5. Neovim plugins
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo " 5/6  nvim +PlugClean +PlugInstall +PlugUpdate"
echo "──────────────────────────────────────────"
nvim +PlugClean +PlugInstall +PlugUpdate +qall; or begin
    echo "  ⚠ nvim plugin update failed (exit $status)"; set had_errors 1
end
echo ""

# ──────────────────────────────────────────────
# 6. jj-backed repos (fetch + fast-forward)
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo " 6/6  repos (jj git fetch + fast-forward)"
echo "──────────────────────────────────────────"

update_jj_repo dotfiles "$HOME/dotfiles" main; or set had_errors 1
echo ""

# ──────────────────────────────────────────────
# Tool presence check
# ──────────────────────────────────────────────
echo "──────────────────────────────────────────"
echo " Tool presence check"
echo "──────────────────────────────────────────"

set -l tools_to_check \
    atuin bat brew bun cargo cargo-binstall cargo-nextest cargo-sweep \
    claude curl direnv eza fd fzf gh git jj just nvim pi rg rustup \
    shellcheck ssh starship tig tmux tokei trash uv zoxide zstd

set -l missing_tools
for tool in $tools_to_check
    if not command -v $tool > /dev/null 2>&1
        set -a missing_tools $tool
    end
end

set -l tool_count (count $tools_to_check)
set -l missing_count (count $missing_tools)

if set -q missing_tools[1]
    echo "  ⚠ Missing tools ($missing_count):"
    for tool in $missing_tools
        echo "     - $tool"
    end
else
    echo "  ✓ All $tool_count tools checked — none missing"
end
echo ""

# ──────────────────────────────────────────────
echo "========================================"
echo "            Summary"
echo "========================================"

set -l summary_items

if test $had_errors -eq 0
    set -a summary_items "  ✓ All updates completed"
else
    set -a summary_items "  ⚠ Some updates had errors (see above)"
end

if set -q swupd_pending[1]; and test $swupd_pending -gt 0
    set -a summary_items "  ℹ  $swupd_pending macOS update(s) pending:"
    for label in $swupd_labels
        set -a summary_items "       - $label"
    end
    set -a summary_items "       (run: softwareupdate --install --all)"
end

if set -q missing_tools[1]
    set -a summary_items "  ⚠ $missing_count tool(s) not found in PATH"
    for tool in $missing_tools
        set -a summary_items "       - $tool"
    end
else
    set -a summary_items "  ✓ All $tool_count tools found in PATH"
end

for item in $summary_items
    echo $item
end
echo "========================================"
