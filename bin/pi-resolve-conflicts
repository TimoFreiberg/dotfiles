#!/usr/bin/env bash
# pi-resolve-conflicts — resolve every local, mutable jj (Jujutsu) conflicted
# commit by delegating to the pi coding agent. That's all it does: no rebase,
# no tests.
#
# jj stores conflicts in commits, but pi can only edit files materialized in a
# working copy — so this checks out each conflicted commit in turn (jj edit),
# lets pi resolve the markers, then moves on. It resolves ancestors before
# descendants (fixing a propagated conflict upstream often clears the ones
# below it) and restores your original working-copy commit when done.
set -euo pipefail

PI_MODEL="${PI_RESOLVE_MODEL:-deepseek/deepseek-v4-pro}"
REPO_ROOT=""
REVSET="mutable()"
LABEL=""
VERBOSE=false

usage() {
  cat <<'EOF'
Usage: pi-resolve-conflicts [OPTIONS]

Resolve every conflicted commit in the target set by delegating to pi. The
default set is all local, mutable commits — i.e. your unpushed work. Each
conflicted commit is checked out (jj edit), resolved by pi, then the next is
processed (ancestors first). Your original working-copy commit is restored at
the end.

Exits 0 if all conflicts were resolved (or there were none), non-zero if any
remain or pi is unavailable.

Options:
  -R, --repo PATH    Repo root / workspace (default: auto-detect via jj root)
  -r, --revset REV   Limit the set to resolve (default: mutable()); it is
                     always intersected with conflicts()
  -m, --model MODEL  pi model (default: $PI_RESOLVE_MODEL or
                     deepseek/deepseek-v4-pro)
  -l, --label TEXT   Extra context woven into pi's prompt (e.g. what produced
                     the conflicts)
  -v, --verbose      Print the tail of pi's output for each commit
  -h, --help         Show this help
EOF
  exit 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -R|--repo)     REPO_ROOT="$2"; shift 2 ;;
    -r|--revset)   REVSET="$2"; shift 2 ;;
    -m|--model)    PI_MODEL="$2"; shift 2 ;;
    -l|--label)    LABEL="$2"; shift 2 ;;
    -v|--verbose)  VERBOSE=true; shift ;;
    -h|--help)     usage ;;
    *)             echo "Unknown flag: $1"; usage ;;
  esac
done

########################################################################
# Resolve repo root
########################################################################
if [[ -z "$REPO_ROOT" ]]; then
  REPO_ROOT="$(jj root 2>/dev/null || echo "")"
  if [[ -z "$REPO_ROOT" ]]; then
    echo "error: not in a jj repo and no --repo given" >&2
    exit 1
  fi
fi
REPO_ROOT="$(cd "$REPO_ROOT" && pwd)"

# The conflicted set we operate on, and its current roots (no conflicted
# ancestor — safe to resolve first).
CONFLICT_SET="($REVSET) & conflicts()"

count_conflicted() {
  jj -R "$REPO_ROOT" log -r "$CONFLICT_SET" --no-graph \
    -T 'change_id.short() ++ "\n"' 2>/dev/null | sed '/^$/d' | wc -l | tr -d ' '
}

########################################################################
# Resolve the conflicts at the current working-copy commit (@) via pi.
# Returns 0 if @ is conflict-free afterwards, 1 otherwise.
########################################################################
resolve_current() {
  local label="$1"
  local conflict_files
  conflict_files=$(jj -R "$REPO_ROOT" resolve --list 2>/dev/null || true)
  if [[ -z "$conflict_files" ]]; then
    return 0
  fi

  echo "  conflicted files:"
  echo "$conflict_files" | while read -r f; do
    [[ -n "$f" ]] && echo "    $f"
  done

  echo "  → delegating to pi ($PI_MODEL)..."

  local prompt_file
  prompt_file=$(mktemp "${TMPDIR:-/tmp}/pi-resolve-conflicts.XXXXXX")

  cat > "$prompt_file" << ENDPROMPT
You are resolving jj (Jujutsu) conflicts in the repository at \`$REPO_ROOT\`.
Working directory: \`$REPO_ROOT\`

The conflicted commit is currently checked out as the working copy ($label).
The following files have conflicts:

$conflict_files

## Conflict marker format

jj materializes each conflict between an opening \`<<<<<<<\` line and a
closing \`>>>>>>>\` line. You may see EITHER style — read the actual file and
handle whichever appears:

Diff style (jj's default — you will usually see this):

    <<<<<<< conflict 1 of N
    %%%%%%% diff from base to side #1
    -<line as it was in the common ancestor>
    +<line as side #1 changed it>
    +++++++ side #2
    <side #2 content, shown literally>
    >>>>>>> conflict 1 of N ends

  Side #1 is expressed as a DIFF against the common ancestor: apply the -/+
  hunk to reconstruct it (a '-' line was removed, a '+' line was added, an
  unprefixed line is unchanged). Side #2 is shown literally. A block may also
  contain a header continuation line starting with a run of backslashes —
  that is a marker, not content.

Git/diff3 style:

    <<<<<<< side #1
    <side #1 content>
    ||||||| common ancestor
    <ancestor content>
    =======
    <side #2 content>
    >>>>>>> side #2

Replace the ENTIRE region — from the \`<<<<<<<\` line through the \`>>>>>>>\`
line, inclusive — with the single correct merged result. None of these marker
tokens may survive anywhere in the file: \`<<<<<<<\`, \`>>>>>>>\`, \`=======\`,
\`|||||||\`, \`%%%%%%%\`, \`+++++++\`, or a run of backslashes.

## What to do

1. For each conflicted file, read it and locate every conflict region.
2. Research until you are confident of the intended result — do NOT guess:
   - Read the surrounding code and any related files.
   - Use \`jj log\` and \`jj show <rev>\` to understand WHY each side changed
     what it did (what commit introduced it, what problem it solved).
   - A conflict almost always means BOTH sides changed something. Your merge
     must preserve the intent of BOTH sides unless one genuinely supersedes
     the other. Never drop a side's change just to silence the conflict.
   - If a region is genuinely ambiguous after research, leave it and report
     it as unresolved rather than guessing.
3. Replace each conflict region with the correct merged content, making the
   MINIMAL change needed:
   - Edit only within the conflict regions. Do NOT reformat, refactor,
     rename, restyle, or otherwise change code outside the markers.
   - Edit ONLY the conflicted files listed above. Do not create, delete, or
     modify any other file.
4. Re-read each file you changed and confirm: it is syntactically coherent,
   both sides' intent is represented, and none of the marker tokens listed
   above remain anywhere.
5. Check your work: \`jj -R $REPO_ROOT resolve --list\` should report no
   conflicts (exit non-zero) at this revision.

## How to respond

- If all conflicts were resolved: describe each conflict, what the two sides
  were, and why your resolution is correct. End with the line "done".
- If a conflict cannot be resolved: describe the file, the conflicting
  changes, what you researched, and why no clear resolution emerged. End with
  the line "unresolved".

## Important

- Do NOT ask questions — resolve everything autonomously, or report a region
  as unresolved if you genuinely cannot.
- Edit files ONLY. jj records your resolution automatically once the markers
  are gone. Do NOT run \`jj rebase\`, \`jj squash\`, \`jj abandon\`, or bare
  \`jj resolve\` (it opens an interactive merge tool and will hang). Read-only
  commands like \`jj log\`, \`jj show\`, and \`jj resolve --list\` are fine.
ENDPROMPT

  local pi_output
  pi_output=$(pi -p --model "$PI_MODEL" --no-session < "$prompt_file" 2>&1) || true
  rm -f "$prompt_file"
  LAST_PI_OUTPUT="$pi_output"

  if [[ "$VERBOSE" == true ]]; then
    echo "  ── pi output ──"
    echo "$pi_output" | tail -20
    echo "  ───────────────"
  fi

  # resolve --list exits 0 while conflicts remain at @, non-zero when clean.
  if jj -R "$REPO_ROOT" resolve --list &>/dev/null; then
    return 1
  fi
  return 0
}

########################################################################
# Main
########################################################################
total=$(count_conflicted)
if [[ "$total" -eq 0 ]]; then
  echo "✓ no conflicts to resolve in: $CONFLICT_SET"
  exit 0
fi

if ! command -v pi &>/dev/null; then
  echo "✗ pi not found on PATH — resolve manually" >&2
  exit 1
fi

echo "→ repo:          $REPO_ROOT"
echo "→ conflict set:  $CONFLICT_SET"
echo "→ conflicted commits: $total"
echo "→ pi model:      $PI_MODEL"

# Remember where we started so we can return here afterwards (change_id is
# stable across the rebases that resolving ancestors triggers).
ORIG=$(jj -R "$REPO_ROOT" log -r @ --no-graph -T 'change_id.short()' 2>/dev/null || echo "")

FAILED=()
LAST_PI_OUTPUT=""  # set by resolve_current, read after failures
ATTEMPTED=" "   # space-padded change_ids we've already handled

while :; do
  # Pick a current root of the conflicted set that we haven't attempted yet.
  roots=$(jj -R "$REPO_ROOT" log -r "roots($CONFLICT_SET)" --no-graph \
    -T 'change_id.short() ++ "\n"' 2>/dev/null || echo "")
  next=""
  while read -r c; do
    [[ -z "$c" ]] && continue
    if [[ "$ATTEMPTED" != *" $c "* ]]; then next="$c"; break; fi
  done <<< "$roots"
  [[ -z "$next" ]] && break

  desc=$(jj -R "$REPO_ROOT" log -r "$next" --no-graph \
    -T 'description.first_line()' 2>/dev/null || echo "")
  [[ -z "$desc" ]] && desc="(no description)"

  echo ""
  echo "── $next  $desc ──"

  if ! jj -R "$REPO_ROOT" edit "$next" 2>&1; then
    echo "  ✗ jj edit failed (skipping)"
    FAILED+=("$next: jj edit failed")
    ATTEMPTED+="$next "
    continue
  fi

  label="commit $next"
  [[ -n "$LABEL" ]] && label="$label — $LABEL"

  if resolve_current "$label"; then
    echo "  ✓ resolved"
  else
    echo "  ✗ pi could not resolve $next"
    if [[ -n "$LAST_PI_OUTPUT" ]]; then
      pi_tail=$(echo "$LAST_PI_OUTPUT" | grep -v '^[[:space:]]*$' | tail -5)
      while IFS= read -r line; do
        echo "    │ $line"
      done <<< "$pi_tail"
    fi
    FAILED+=("$next")
  fi
  ATTEMPTED+="$next "
done

########################################################################
# Restore original working-copy commit
########################################################################
if [[ -n "$ORIG" ]] && jj -R "$REPO_ROOT" log -r "$ORIG" --no-graph -T '""' &>/dev/null; then
  jj -R "$REPO_ROOT" edit "$ORIG" &>/dev/null || true
fi

########################################################################
# Report
########################################################################
echo ""
echo "═══════════════════════════════════════"
remaining=$(jj -R "$REPO_ROOT" log -r "$CONFLICT_SET" --no-graph \
  -T 'change_id.short() ++ " " ++ description.first_line() ++ "\n"' 2>/dev/null || echo "")
remaining_trimmed=$(echo "$remaining" | tr -d '[:space:]')
if [[ -z "$remaining_trimmed" ]]; then
  echo "✓ all conflicts resolved"
  exit 0
else
  echo "✗ conflicts remain in:"
  echo "$remaining" | while read -r c; do [[ -n "$c" ]] && echo "    $c"; done
  exit 1
fi
