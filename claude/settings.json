{
  "awsAuthRefresh": "aws sso login --sso-session \"$SSO_SESSION\" 2>/dev/null || aws sso login --profile \"$AWS_PROFILE\"",
  "includeGitInstructions": false,
  "env": {
    "PAGER": "cat",
    "GIT_PAGER": "cat",
    "MANPAGER": "cat",
    "EDITOR": "false",
    "VISUAL": "false",
    "GIT_EDITOR": "false",
    "JJ_EDITOR": "false"
  },
  "permissions": {
    "allow": [
      "Bash(jj *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(cargo *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(test *)",
      "Bash([ *)",
      "Bash(diff *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(which *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(xargs *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(pwd*)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(date*)",
      "Bash(uname*)",
      "Bash(ln *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(mktemp*)",
      "Bash(tee *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(ps *)",
      "Bash(open *)",
      "Bash(pbcopy*)",
      "Bash(pbpaste*)",
      "Bash(jq *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(brew *)",
      "Bash(nix *)",
      "Bash(docker *)",
      "Bash(make *)",
      "Bash(rustup *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(unzip *)",
      "Bash(just *)",
      "Bash(todo *)",
      "Bash(ruff *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-create.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/post-edit-format.py",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-commit-memories.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "learning-opportunities@learning-opportunities": true
  },
  "extraKnownMarketplaces": {
    "learning-opportunities": {
      "source": {
        "source": "git",
        "url": "https://github.com/DrCatHicks/learning-opportunities.git"
      }
    }
  },
  "effortLevel": "xhigh",
  "autoMemoryDirectory": "~/dotfiles/claude/memories",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
